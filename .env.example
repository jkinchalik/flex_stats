# Riot API
RIOT_API_KEY=
RIOT_PLATFORM=na1
RIOT_REGION=americas
# Optional: override the default 100 req / 120 s budget. Format "count:seconds".
# RIOT_APP_RATE_LIMIT=100:120

# Postgres connection string (Railway provides this as ${{ Postgres.DATABASE_PUBLIC_URL }}
# when you reference the Postgres service in Railway env vars).
DATABASE_URL=

# Generate with: openssl rand -hex 32
CRON_SECRET=
